# ─────────────────────────────────────────────────────────────────────────────
# Copy this to setup.env and fill in your values.
# setup.env is git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP (auto-detected from gcloud config if blank) ──────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_ZONE=us-central1-a

# ── GCP VM ────────────────────────────────────────────────────────────────────
VM_NAME=otel-lab-yourname

# ── Grafana Cloud — OTLP (required) ──────────────────────────────────────────
# Where to find these:
#   OTLP Endpoint  → grafana.com → your stack → OpenTelemetry tile → Details
#   Instance ID    → grafana.com → your stack → Grafana tile → Details (a number)
#   API token      → grafana.com → your stack → Access Policies → Create token
#                    Required scopes: metrics:write, logs:write, traces:write

GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_INSTANCE_ID=123456
GRAFANA_API_TOKEN=glc_eyJ...

# ── Grafana Cloud — Kubernetes Monitoring (optional) ─────────────────────────
# Leave blank to skip Kubernetes infrastructure monitoring.
# If set, deploys Grafana Alloy to collect cluster/node/pod metrics and logs.
#
# Where to find these:
#   Prometheus tile → Details → Remote Write Endpoint  (host only, no path)
#                              Details → Username
#   Loki tile       → Details → URL                    (host only, no path)
#                              Details → Username

GRAFANA_PROMETHEUS_HOST=https://prometheus-prod-13-prod-us-east-0.grafana.net
GRAFANA_PROMETHEUS_USERNAME=943748
GRAFANA_LOKI_HOST=https://logs-prod-us-east-0.grafana.net
GRAFANA_LOKI_USERNAME=738291

# ── Grafana Cloud — Dashboard Auto-Import (optional) ─────────────────────────
# Leave blank to skip automatic dashboard import.
# If set, the wizard imports all OTel Demo dashboards into an "OTel Demo" folder.
#
# Where to find these:
#   Grafana URL    → grafana.com → your stack → Launch Grafana → copy the URL
#   SA Token       → Grafana → Administration → Service Accounts → Add service account
#                    Set role: Editor, then Add token

GRAFANA_URL=https://yourorg.grafana.net
GRAFANA_SA_TOKEN=glsa_...
